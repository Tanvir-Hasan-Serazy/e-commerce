model Category {
    id                 Int       @id @default(autoincrement())
    name               String    @unique
    imageURL           String?
    cloudinaryPublicID String?
    products           Product[]
    createdAt          DateTime  @default(now())
    updatedAt          DateTime  @updatedAt

    @@map("category")
}

model Product {
    id                 Int      @id @default(autoincrement())
    name               String
    imageURL           String[]
    cloudinaryPublicID String
    description        String
    stock              Int
    originalPrice      Float
    salePrice          Float
    categoryId         Int
    category           Category @relation(fields: [categoryId], references: [id])
    brand              String
    warranty           String
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt

    @@index([categoryId])
    @@map("product")
}
