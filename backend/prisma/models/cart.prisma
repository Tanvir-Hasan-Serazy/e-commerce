model Cart {
    id     String     @id @default(cuid())
    userId String
    user   User       @relation(fields: [userId], references: [id])
    items  CartItem[]

    @@map("cart")
}

model CartItem {
    id        String @id @default(uuid())
    cartId    String
    productID Int
    quantity  Int
    cart      Cart   @relation(fields: [cartId], references: [id])

    @@map("cart_item")
}
