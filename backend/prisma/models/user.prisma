enum Role {
    ADMIN
    STAFF
    USER
}

model User {
    id          String   @id @default(cuid())
    firstName   String
    lastName    String
    email       String   @unique
    userName    String   @unique
    dateOfBirth DateTime
    password    String
    role        Role     @default(USER)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@map("users")
}
